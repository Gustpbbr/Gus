def _persist_transcript_pra_cron(transcript: str) -> Path:
    """Salva transcript em pasta processada pelo cron GitHub Actions.
    Esse é o caminho que funciona quando ambiente Web não tem env vars."""
    transcripts_dir = REPO_ROOT / "_log" / "transcripts-claude-code"
    transcripts_dir.mkdir(parents=True, exist_ok=True)

    session_id = uuid.uuid4().hex[:12]
    nome = f"{datetime.now(BRT).strftime('%Y-%m-%dT%H-%M')}__{session_id}.jsonl"
    out_path = transcripts_dir / nome

    # Filtra PII via regex existente em gus.patterns_sensiveis
    try:
        from gus.patterns_sensiveis import redact
        transcript_safe = redact(transcript)
    except Exception:
        transcript_safe = transcript  # fallback: não filtra

    out_path.write_text(transcript_safe, encoding="utf-8")
    return out_path

# Em main(), DEPOIS do _ler_transcript:
out_path = _persist_transcript_pra_cron(transcript)
log.info(f"Transcript salvo pra cron processar: {out_path.name}")

# Daí tenta extrair via Haiku (legacy path, pode falhar sem env vars):
try:
    fragmentos = _extrair_fragmentos(transcript)
    # ...
except RuntimeError:
    # Já salvou pra cron — vida segue
    _logar_sessao(0, 0, [str(e)], f"(transcript {out_path.name} salvo pra cron)")
