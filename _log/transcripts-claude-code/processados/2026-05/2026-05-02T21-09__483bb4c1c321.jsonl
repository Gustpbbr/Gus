.connection__preview {
  font-size: var(--fs-small); color: var(--text-soft); line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}

.panel__delete {
  margin: 0 var(--s-6) var(--s-6);
  padding: 12px;
  background: rgba(248,113,113,0.05);
  border: 1px solid rgba(248,113,113,0.2);
  border-radius: 8px; color: var(--danger);
  font-family: inherit; font-size: var(--fs-micro);
  letter-spacing: 0.12em; text-transform: uppercase;
  cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; justify-content: center; gap: var(--s-2);
}
.panel__delete:hover { background: rgba(248,113,113,0.12); border-color: var(--danger); }

/* ─── Labels ─── */
.label-canvas { position: fixed; inset: 0; pointer-events: none; z-index: 30; }

.node-label {
  position: absolute;
  transform: translate(-50%, -120%);
  pointer-events: none; opacity: 0;
  transition: opacity 0.4s cubic-bezier(0.16,1,0.3,1),
              transform 0.4s cubic-bezier(0.16,1,0.3,1);
}
.node-label.is-visible  { opacity: 1; transform: translate(-50%, -132%); }
.node-label.is-selected { opacity: 1; transform: translate(-50%, -138%); }

.label-card {
  position: relative;
  background: rgba(8,8,28,0.88);
  border: 1px solid var(--hairline); border-radius: 10px;
  padding: 9px 13px; max-width: 220px;
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
}
.label-card::after {
  content: ''; position: absolute;
  bottom: -16px; left: 50%; transform: translateX(-50%);
  width: 1px; height: 16px;
  background: linear-gradient(to bottom, currentColor, transparent);
  opacity: 0.4;
}
.label-card__type {
  font-size: 9px; letter-spacing: 0.22em;
  text-transform: uppercase; margin-bottom: 4px; line-height: 1;
}
.label-card__text {
  font-family: 'Instrument Serif', serif;
  font-size: 13px; color: var(--text); line-height: 1.35;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ─── Toast ─── */
.toast {
  position: fixed; bottom: var(--s-8); right: 110px;
  z-index: 200; max-width: 280px;
  background: var(--panel); border: 1px solid var(--hairline);
  border-radius: 12px; padding: var(--s-3) var(--s-4);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  opacity: 0; transform: translateY(16px);
  transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
  pointer-events: none;
  display: flex; gap: var(--s-3); align-items: flex-start;
}
.toast.is-shown { opacity: 1; transform: translateY(0); }
.toast__indicator {
  width: 8px; height: 8px; border-radius: 50%;
  margin-top: 5px; flex-shrink: 0;
  box-shadow: 0 0 10px currentColor;
}
.toast__body { flex: 1; min-width: 0; }
.toast__label {
  font-size: var(--fs-eyebrow); letter-spacing: 0.18em;
  text-transform: uppercase; margin-bottom: 3px;
}
.toast__text { font-size: var(--fs-small); color: var(--text); line-height: 1.4; word-break: break-word; }

/* ─── Hint ─── */
.hint {
  position: fixed; bottom: var(--s-8); left: 50%;
  transform: translateX(-50%);
  font-size: var(--fs-eyebrow); letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--text-faint);
  pointer-events: none; transition: opacity 0.5s; z-index: 40;
}

/* ─── Abas de navegação ─── */
.tabs {
  display: flex;
  gap: 4px;
  background: rgba(8, 8, 28, 0.6);
  border: 1px solid var(--hairline);
  border-radius: 999px;
  padding: 4px;
  pointer-events: auto;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.tab {
  appearance: none;
  background: transparent;
  border: none;
  color: var(--text-mute);
  font-family: inherit;
  font-size: var(--fs-eyebrow);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 8px 16px;
  cursor: pointer;
  border-radius: 999px;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.tab svg {
  width: 14px;
  height: 14px;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.tab:hover {
  color: var(--text-soft);
}
.tab:hover svg { opacity: 1; }

.tab.is-active {
  color: var(--text);
  background: rgba(255, 255, 255, 0.06);
}
.tab.is-active svg {
  opacity: 1;
  color: var(--c-identidade);
}

/* ─── View Lista ─── */
.list-view {
  position: fixed;
  inset: 0;
  z-index: 3;
  background: var(--bg-deep);
  display: none;
  flex-direction: column;
  padding-top: 110px;
}

.list-view.is-active {
  display: flex;
}

.list-view::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 30% 30%, rgba(0, 245, 255, 0.025), transparent 70%),
    radial-gradient(ellipse 50% 40% at 80% 70%, rgba(192, 132, 252, 0.02), transparent 70%);
  pointer-events: none;
  z-index: -1;
}

.list-view__header {
  padding: 0 var(--s-8) var(--s-5);
  flex-shrink: 0;
}

.list-view__title {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-size: 28px;
  font-weight: 400;
  letter-spacing: -0.01em;
  color: var(--text);
  margin-bottom: 6px;
}

.list-view__sub {
  font-size: var(--fs-eyebrow);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-mute);
}

.list-view__body {
  flex: 1;
  overflow-y: auto;
  padding: var(--s-4) var(--s-8) var(--s-10);
}

.list-view__body::-webkit-scrollbar { width: 4px; }
.list-view__body::-webkit-scrollbar-track { background: transparent; }
.list-view__body::-webkit-scrollbar-thumb {
  background: var(--hairline);
  border-radius: 2px;
}

.area-group {
  margin-bottom: var(--s-8);
}

.area-group__head {
  display: flex;
  align-items: baseline;
  gap: var(--s-3);
  padding-bottom: var(--s-3);
  margin-bottom: var(--s-3);
  border-bottom: 1px solid var(--hairline);
}

.area-group__name {
  font-family: 'Instrument Serif', serif;
  font-size: 20px;
  font-style: italic;
  color: var(--text);
  text-transform: lowercase;
  letter-spacing: -0.005em;
}

.area-group__count {
  font-size: var(--fs-eyebrow);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-faint);
  font-variant-numeric: tabular-nums;
}

.area-group__items {
  display: flex;
  flex-direction: column;
  gap: var(--s-2);
}

.list-item {
  display: flex;
  align-items: flex-start;
  gap: var(--s-3);
  padding: var(--s-3) var(--s-4);
  background: var(--glass);
  border: 1px solid var(--hairline);
  border-radius: 10px;
  cursor: pointer;
  transition: all 0.2s;
  text-align: left;
}

.list-item:hover {
  border-color: rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.04);
  transform: translateX(2px);
}

.list-item__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-top: 6px;
  flex-shrink: 0;
  box-shadow: 0 0 8px currentColor;
}

.list-item__body {
  flex: 1;
  min-width: 0;
}

.list-item__top {
  display: flex;
  align-items: center;
  gap: var(--s-3);
  margin-bottom: 4px;
  flex-wrap: wrap;
}

.list-item__type {
  font-size: var(--fs-eyebrow);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.list-item__meta {
  font-size: var(--fs-eyebrow);
  letter-spacing: 0.12em;
  color: var(--text-faint);
  text-transform: uppercase;
}

.list-item__content {
  font-family: 'Instrument Serif', serif;
  font-size: 15px;
  line-height: 1.45;
  color: var(--text-soft);
  letter-spacing: -0.005em;
}

.list-item__conf {
  font-size: var(--fs-eyebrow);
  letter-spacing: 0.12em;
  color: var(--text-mute);
  margin-top: 4px;
  font-variant-numeric: tabular-nums;
}

.list-empty {
  text-align: center;
  padding: 60px 20px;
  color: var(--text-faint);
  font-size: var(--fs-small);
  letter-spacing: 0.1em;
}

/* Quando lista está ativa, esconder elementos da view cosmos */
body.view-list #graph,
body.view-list .filters,
body.view-list .controls,
body.view-list .label-canvas,
body.view-list .edge-indicators,
body.view-list .hint {
  display: none;
}

/* ─── Responsivo ─── */
@media (max-width: 768px) {
  .header { padding: var(--s-4) var(--s-5); }
  .brand__name { font-size: 26px; }
  .stats { gap: var(--s-5); }
  .stat__value { font-size: 22px; }
  .filters { top: 88px; left: var(--s-5); }
  .filters__header { width: 140px; }
  .panel { width: 100vw; }
  .controls { bottom: var(--s-4); right: var(--s-4); }
  .zoom-slider { height: 90px; }
  .toast { bottom: 110px; right: var(--s-5); left: var(--s-5); max-width: none; }

  .tab { padding: 8px 10px; }
  .tab span { display: none; }
  .tab svg { width: 16px; height: 16px; }

  .list-view { padding-top: 90px; }
  .list-view__header { padding: 0 var(--s-5) var(--s-4); }
  .list-view__title { font-size: 22px; }
  .list-view__body { padding: var(--s-3) var(--s-5) var(--s-10); }
  .area-group { margin-bottom: var(--s-6); }
  .area-group__name { font-size: 17px; }
}

@media (max-width: 480px) {
  .stats { display: none; }
}
</style>
</head>
