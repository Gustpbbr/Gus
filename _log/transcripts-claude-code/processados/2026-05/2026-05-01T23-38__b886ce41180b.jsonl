// ─── Painel ───
function openPanel(node) {
  state.selectedId = node.id;
  state.spinning = false;
  updateAutoRotateBtn();
  const data = getFilteredData();

  const neighbors = new Set([node.id]);
  data.links.forEach((l) => {
    const { s, t } = linkExtract(l);
    if (s === node.id) neighbors.add(t);
    if (t === node.id) neighbors.add(s);
  });
  state.selectedNeighbors = neighbors;

  const c = node.color;
  $('panel-glow').style.color = c;
  $('panel-type').textContent = node.tipo.replace(/_/g, ' ');
  $('panel-type').style.color = c;
  $('panel-content').textContent = node.conteudo;

  const body = $('panel-body');
  body.innerHTML = '';

  const meta = [
    { k: 'curador',  v: node.curador },
    { k: 'área',     v: node.area },
    { k: 'camada',   v: node.camada },
    { k: 'id',       v: node.id },
    { k: 'data', v: new Date(node.timestamp).toLocaleDateString('pt-BR', {
        day: '2-digit', month: 'short', year: 'numeric',
    }) },
  ];

  meta.forEach(({ k, v }) => {
    const r = document.createElement('div');
    r.className = 'meta-row';
    r.innerHTML = `<span class="meta-row__key">${k}</span><span class="meta-row__value">${v}</span>`;
    body.appendChild(r);
  });

  const conf = document.createElement('div');
  conf.className = 'confidence';
  conf.innerHTML = `
    <div class="confidence__row">
      <span class="meta-row__key">confiança</span>
      <span class="meta-row__value" style="color:${c};font-family:'Instrument Serif',serif;font-size:18px">
        ${(node.confianca * 100).toFixed(0)}<span style="font-size:11px;opacity:0.6">%</span>
      </span>
    </div>
    <div class="confidence__bar">
      <div class="confidence__fill" style="width:${node.confianca * 100}%;background:${c};color:${c}"></div>
    </div>
  `;
  body.appendChild(conf);

  const conns = data.links.filter((l) => {
    const { s, t } = linkExtract(l);
    return s === node.id || t === node.id;
  });

  if (conns.length) {
    const title = document.createElement('div');
    title.className = 'section-title';
    title.innerHTML = `conexões <span class="section-title__count">· ${conns.length}</span>`;
    body.appendChild(title);

    conns.forEach((l) => {
      const { s, t } = linkExtract(l);
      const otherId = s === node.id ? t : s;
      const other = state.nodeMap.get(otherId);
      if (!other) return;
      const ci = document.createElement('div');
      ci.className = 'connection';
      ci.innerHTML = `
        <span class="connection__type" style="color:${other.color}">${other.tipo.replace(/_/g, ' ')}</span>
        <span class="connection__preview">${other.conteudo}</span>
      `;
      ci.addEventListener('click', () => openPanel(other));
      body.appendChild(ci);
    });
  }

  $('panel').classList.add('is-open');
  $('hint').style.opacity = '0';
}

function closePanel() {
  $('panel').classList.remove('is-open');
  state.selectedId = null;
  state.selectedNeighbors = new Set();
  state.spinning = true;
  updateAutoRotateBtn();
  setTimeout(() => { $('hint').style.opacity = '1'; }, 600);
}

$('panel-close').addEventListener('click', closePanel);

$('panel-delete').addEventListener('click', () => {
  if (!state.selectedId) return;
  const id = state.selectedId;
  state.nodes = state.nodes.filter((n) => n.id !== id);
  state.nodeMap.delete(id);
  state.links = state.links.filter((l) => {
    const { s, t } = linkExtract(l);
    return s !== id && t !== id;
  });
  removeLabel(id);
  state.selectedNeighbors = new Set();
  Graph.graphData(getFilteredData());
  updateStats();
  closePanel();
  showToast('fragmento removido', 'apagado', '#f87171');
});

// ─── Toast ───
function showToast(text, label, color) {
  $('toast-label').textContent = label || 'novo fragmento';
  $('toast-label').style.color = color || 'var(--c-identidade)';
  $('toast-text').textContent = text;
  $('toast-dot').style.background = color || 'var(--c-identidade)';
  $('toast-dot').style.color = color || 'var(--c-identidade)';
  const el = $('toast');
  el.classList.add('is-shown');
  setTimeout(() => el.classList.remove('is-shown'), 3800);
}

// ─── Adicionar fragmento (pra integração futura com hub via SSE/polling) ───
// Aceita um objeto com campos reais do hub. Se chamado sem args, não faz nada.
function addFragment(raw) {
  if (!raw || !raw.conteudo) return;
  const color = TYPE_COLOR[raw.tipo] || '#ffffff';
  const node = {
    id: raw.id || ('new_' + (++state.nextId)),
    conteudo: raw.conteudo,
    tipo: raw.tipo || 'episodico',
    area: raw.area || '',
    curador: raw.curador || 'desconhecido',
    camada: raw.camada || 'sessao',
    confianca: raw.confianca || 0.7,
    timestamp: raw.criado_em || new Date().toISOString(),
    color,
    val: 0.8 + (raw.confianca || 0.7) * 0.8,
    _isNew: true,
  };
  state.nodes.push(node);
  state.nodeMap.set(node.id, node);
  const peers = state.nodes.filter((p) => p.tipo === node.tipo && p.id !== node.id);
  if (peers.length) {
    state.links.push({ source: node.id, target: peers[peers.length - 1].id });
  }
  Graph.graphData(getFilteredData());
  setTimeout(() => {
    node._isNew = false;
    Graph.graphData(getFilteredData());
  }, 2200);
  updateStats();
  showToast(
    node.conteudo.length > 70 ? node.conteudo.slice(0, 70) + '…' : node.conteudo,
    node.tipo.replace(/_/g, ' '),
    color
  );
}

// Auto-fragmento desativado — só dispara via integração real com hub
// setInterval(addFragment, 9000);

// ─── Resize ───
window.addEventListener('resize', () => {
  Graph.width(window.innerWidth).height(window.innerHeight);
});

// ─── Keyboard ───
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && state.selectedId) closePanel();
  if (e.key === '+' || e.key === '=') setZoom(0.85);
  if (e.key === '-' || e.key === '_') setZoom(1.18);
  if (e.key === '0') fitAll();
});

// Inicial: filtros recolhidos por padrão depois de 2s
setTimeout(() => {
  filtersEl.classList.add('is-collapsed');
  filtersToggle.setAttribute('aria-expanded', 'false');
}, 2500);
</script>
