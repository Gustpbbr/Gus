function setView(view) {
  state.view = view;
  tabCosmosBtn.classList.toggle('is-active', view === 'cosmos');
  tabListBtn.classList.toggle('is-active', view === 'list');
  listViewEl.classList.toggle('is-active', view === 'list');
  document.body.classList.toggle('view-list', view === 'list');

  if (view === 'list') {
    renderList();
    state.spinning = false;
    if (typeof updateAutoRotateBtn === 'function') updateAutoRotateBtn();
  } else {
    if (!state.selectedId) {
      state.spinning = true;
      if (typeof updateAutoRotateBtn === 'function') updateAutoRotateBtn();
    }
  }
}

tabCosmosBtn.addEventListener('click', () => setView('cosmos'));
tabListBtn.addEventListener('click', () => setView('list'));

// ─── Renderização da Lista por área ───
function renderList() {
  const body = $('list-view-body');
  body.innerHTML = '';

  if (!state.nodes.length) {
    body.innerHTML = '<div class="list-empty">nenhum fragmento</div>';
    return;
  }

  const byArea = {};
  for (const n of state.nodes) {
    const area = n.area || 'sem área';
    if (!byArea[area]) byArea[area] = [];
    byArea[area].push(n);
  }

  const sortedAreas = Object.keys(byArea).sort((a, b) =>
    byArea[b].length - byArea[a].length
  );

  const connCount = new Map();
  state.links.forEach(l => {
    const s = typeof l.source === 'object' ? l.source.id : l.source;
    const t = typeof l.target === 'object' ? l.target.id : l.target;
    connCount.set(s, (connCount.get(s) || 0) + 1);
    connCount.set(t, (connCount.get(t) || 0) + 1);
  });

  for (const area of sortedAreas) {
    const items = byArea[area];

    const groupEl = document.createElement('section');
    groupEl.className = 'area-group';

    const head = document.createElement('div');
    head.className = 'area-group__head';
    head.innerHTML = `
      <span class="area-group__name">${area}</span>
      <span class="area-group__count">${items.length} ${items.length === 1 ? 'fragmento' : 'fragmentos'}</span>
    `;
    groupEl.appendChild(head);

    const itemsList = document.createElement('div');
    itemsList.className = 'area-group__items';

    items.sort((a, b) => (b.timestamp || '').localeCompare(a.timestamp || ''));

    for (const node of items) {
      const item = document.createElement('button');
      item.className = 'list-item';
      const dataFmt = node.timestamp
        ? new Date(node.timestamp).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })
        : '—';
      const conns = connCount.get(node.id) || 0;
      item.innerHTML = `
        <span class="list-item__dot" style="background:${node.color};color:${node.color}"></span>
        <div class="list-item__body">
          <div class="list-item__top">
            <span class="list-item__type" style="color:${node.color}">${node.tipo.replace(/_/g, ' ')}</span>
            <span class="list-item__meta">${dataFmt} · ${node.curador}</span>
            ${conns ? `<span class="list-item__meta">${conns} ${conns === 1 ? 'conexão' : 'conexões'}</span>` : ''}
          </div>
          <div class="list-item__content">${node.conteudo}</div>
          <div class="list-item__conf">confiança ${(node.confianca * 100).toFixed(0)}%</div>
        </div>
      `;
      item.addEventListener('click', () => {
        setView('cosmos');
        setTimeout(() => openPanel(node), 50);
      });
      itemsList.appendChild(item);
    }

    groupEl.appendChild(itemsList);
    body.appendChild(groupEl);
  }
}

// ─── Filtros ───
const filtersEl = $('filters');
const filtersToggle = $('filters-toggle');
const filtersList = $('filters-list');

filtersToggle.addEventListener('click', () => {
  const collapsed = filtersEl.classList.toggle('is-collapsed');
  filtersToggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
});

function applyFilter(f) {
  state.filter = f;
  state.showLabels = f !== 'none';

  document.querySelectorAll('.chip').forEach((b) => {
    if (b.dataset.filter === '__halo') return;
    b.classList.toggle('is-active', b.dataset.filter === f);
  });

  $('filters-label').textContent = TYPE_LABEL[f] || f;
  const dotEl = $('filters-dot');
  if (f === 'all') {
    dotEl.style.background = '#fff';
    dotEl.style.border = 'none';
  } else if (f === 'none') {
    dotEl.style.background = 'transparent';
    dotEl.style.border = '1px dashed var(--text-faint)';
  } else {
    dotEl.style.background = TYPE_COLOR[f];
    dotEl.style.border = 'none';
    dotEl.style.boxShadow = `0 0 6px ${TYPE_COLOR[f]}`;
  }

  clearAllLabels();
  state.selectedNeighbors = new Set();
  Graph.graphData(getFilteredData());

  setTimeout(() => {
    filtersEl.classList.add('is-collapsed');
    filtersToggle.setAttribute('aria-expanded', 'false');
  }, 250);
}

document.querySelectorAll('.chip').forEach((btn) => {
  btn.addEventListener('click', () => {
    if (btn.dataset.filter === '__halo') {
      state.showHalo = !state.showHalo;
      btn.classList.toggle('is-active', state.showHalo);
      Graph.graphData(getFilteredData());
      return;
    }
    applyFilter(btn.dataset.filter);
  });
});

// ─── Painel ───
function openPanel(node) {
  state.selectedId = node.id;
  state.spinning = false;
  updateAutoRotateBtn();
  const data = getFilteredData();

  const neighbors = new Set([node.id]);
  data.links.forEach((l) => {
    const { s, t } = linkExtract(l);
    if (s === node.id) neighbors.add(t);
    if (t === node.id) neighbors.add(s);
  });
  state.selectedNeighbors = neighbors;

  const c = node.color;
  $('panel-glow').style.color = c;
  $('panel-type').textContent = node.tipo.replace(/_/g, ' ');
  $('panel-type').style.color = c;
  $('panel-content').textContent = node.conteudo;

  const body = $('panel-body');
  body.innerHTML = '';

  const meta = [
    { k: 'curador',  v: node.curador },
    { k: 'área',     v: node.area },
    { k: 'camada',   v: node.camada },
    { k: 'id',       v: node.id },
    { k: 'data', v: new Date(node.timestamp).toLocaleDateString('pt-BR', {
        day: '2-digit', month: 'short', year: 'numeric',
    }) },
  ];

  meta.forEach(({ k, v }) => {
    const r = document.createElement('div');
    r.className = 'meta-row';
    r.innerHTML = `<span class="meta-row__key">${k}</span><span class="meta-row__value">${v}</span>`;
    body.appendChild(r);
  });

  const conf = document.createElement('div');
  conf.className = 'confidence';
  conf.innerHTML = `
    <div class="confidence__row">
      <span class="meta-row__key">confiança</span>
      <span class="meta-row__value" style="color:${c};font-family:'Instrument Serif',serif;font-size:18px">
        ${(node.confianca * 100).toFixed(0)}<span style="font-size:11px;opacity:0.6">%</span>
      </span>
    </div>
    <div class="confidence__bar">
      <div class="confidence__fill" style="width:${node.confianca * 100}%;background:${c};color:${c}"></div>
    </div>
  `;
  body.appendChild(conf);

  const conns = data.links.filter((l) => {
    const { s, t } = linkExtract(l);
    return s === node.id || t === node.id;
  });

  if (conns.length) {
    const title = document.createElement('div');
    title.className = 'section-title';
    title.innerHTML = `conexões <span class="section-title__count">· ${conns.length}</span>`;
    body.appendChild(title);

    conns.forEach((l) => {
      const { s, t } = linkExtract(l);
      const otherId = s === node.id ? t : s;
      const other = state.nodeMap.get(otherId);
      if (!other) return;
      const ci = document.createElement('div');
      ci.className = 'connection';
      ci.innerHTML = `
        <span class="connection__type" style="color:${other.color}">${other.tipo.replace(/_/g, ' ')}</span>
        <span class="connection__preview">${other.conteudo}</span>
      `;
      ci.addEventListener('click', () => openPanel(other));
      body.appendChild(ci);
    });
  }

  $('panel').classList.add('is-open');
  $('hint').style.opacity = '0';
}

function closePanel() {
  $('panel').classList.remove('is-open');
  state.selectedId = null;
  state.selectedNeighbors = new Set();
  state.spinning = true;
  updateAutoRotateBtn();
  setTimeout(() => { $('hint').style.opacity = '1'; }, 600);
}

$('panel-close').addEventListener('click', closePanel);

$('panel-delete').addEventListener('click', () => {
  if (!state.selectedId) return;
  const id = state.selectedId;
  state.nodes = state.nodes.filter((n) => n.id !== id);
  state.nodeMap.delete(id);
  state.links = state.links.filter((l) => {
    const { s, t } = linkExtract(l);
    return s !== id && t !== id;
  });
  removeLabel(id);
  state.selectedNeighbors = new Set();
  Graph.graphData(getFilteredData());
  updateStats();
  closePanel();
  showToast('fragmento removido', 'apagado', '#f87171');
});

// ─── Toast ───
function showToast(text, label, color) {
  $('toast-label').textContent = label || 'novo fragmento';
  $('toast-label').style.color = color || 'var(--c-identidade)';
  $('toast-text').textContent = text;
  $('toast-dot').style.background = color || 'var(--c-identidade)';
  $('toast-dot').style.color = color || 'var(--c-identidade)';
  const el = $('toast');
  el.classList.add('is-shown');
  setTimeout(() => el.classList.remove('is-shown'), 3800);
}

// ─── Adicionar fragmento (pra integração futura na Parte 1B com SSE) ───
function addFragment(raw) {
  if (!raw || !raw.conteudo) return;
  const color = getNodeColor(raw);
  const node = {
    id: raw.id || ('new_' + (++state.nextId)),
    conteudo: raw.conteudo,
    tipo: raw.tipo || 'episodico',
    area: raw.area || '',
    curador: raw.curador || 'desconhecido',
    camada: raw.camada || 'sessao',
    confianca: raw.confianca || 0.7,
    timestamp: raw.criado_em || new Date().toISOString(),
    color,
    val: 0.8 + (raw.confianca || 0.7) * 0.8,
    _isNew: true,
  };
  state.nodes.push(node);
  state.nodeMap.set(node.id, node);
  const peers = state.nodes.filter((p) => p.tipo === node.tipo && p.id !== node.id);
  if (peers.length) {
    state.links.push({ source: node.id, target: peers[peers.length - 1].id });
  }
  Graph.graphData(getFilteredData());
  setTimeout(() => {
    node._isNew = false;
    Graph.graphData(getFilteredData());
  }, 2200);
  updateStats();
  showToast(
    node.conteudo.length > 70 ? node.conteudo.slice(0, 70) + '…' : node.conteudo,
    node.tipo.replace(/_/g, ' '),
    color
  );
}

// ─── Resize ───
window.addEventListener('resize', () => {
  Graph.width(window.innerWidth).height(window.innerHeight);
});

// ─── Keyboard ───
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && state.selectedId) closePanel();
  if (e.key === '+' || e.key === '=') setZoom(0.85);
  if (e.key === '-' || e.key === '_') setZoom(1.18);
  if (e.key === '0') fitAll();
});

// Inicial: filtros recolhidos por padrão depois de 2.5s
setTimeout(() => {
  filtersEl.classList.add('is-collapsed');
  filtersToggle.setAttribute('aria-expanded', 'false');
}, 2500);
</script>
</body>
</html>
