  const visibleEdgeIds = new Set();
  const MARGIN = 28;
  projected.forEach((p) => {
    if (p.onScreen) return;
    visibleEdgeIds.add(p.node.id);
    const dot = getOrCreateEdgeDot(p.node.id, p.node.color);

    let dx = p.x - W / 2;
    let dy = p.y - H / 2;
    if (p.worldPos && p.worldPos.distanceTo(cam.position) > 0) {
      const cameraForward = new THREE.Vector3();
      cam.getWorldDirection(cameraForward);
      const toNode = p.worldPos.clone().sub(cam.position);
      if (toNode.dot(cameraForward) < 0) {
        dx = -dx; dy = -dy;
      }
    }
    const angle = Math.atan2(dy, dx);
    const halfW = W / 2 - MARGIN;
    const halfH = H / 2 - MARGIN;
    let edgeX, edgeY;
    const tanA = Math.tan(angle);
    if (Math.abs(halfW * tanA) <= halfH) {
      edgeX = (dx > 0 ? halfW : -halfW);
      edgeY = edgeX * tanA;
    } else {
      edgeY = (dy > 0 ? halfH : -halfH);
      edgeX = edgeY / tanA;
    }
    dot.style.left = (W / 2 + edgeX) + 'px';
    dot.style.top  = (H / 2 + edgeY) + 'px';
